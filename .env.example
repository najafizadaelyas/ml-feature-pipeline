# AWS credentials (real AWS or LocalStack)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1

# Set to LocalStack endpoint when developing locally
# AWS_ENDPOINT_URL=http://localhost:4566

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production

# Pipeline
PIPELINE_CONFIG_PATH=config/pipeline_config.yaml
PIPELINE_CONFIG_DIR=config
